%{ for rg, rg_name in rg_config }resource "azurerm_management_lock" "${rg}_lock" {
  name       = "PreventDeleting"
  scope      = azurerm_resource_group.${rg}_lock.id
  lock_level = "CanNotDelete"
  notes      = "Items can't be deleted in this resource group. Before deleting resources, please remove this lock."
}

%{ endfor ~}